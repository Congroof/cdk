DATABASE_URL=mysql://cdk:change-me@127.0.0.1:3306/cdk_server
JWT_SECRET=replace-with-a-long-random-secret
SERVER_ADDR=0.0.0.0:3000

# Base64 of exactly 32 random bytes. Keep this value stable across restarts.
KDOCS_CREDENTIAL_KEY=replace-with-base64-32-byte-key

SKINFORGE_HASH_SYNC_ENABLED=true
